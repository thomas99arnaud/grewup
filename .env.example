# Application
DEBUG=false
APP_NAME=Grew

# Database (SQLite par défaut, PostgreSQL en prod)
DATABASE_URL=sqlite+aiosqlite:///data/grew.db
# DATABASE_URL=postgresql+asyncpg://grew:grew@localhost:5432/grew

# Redis (pour le worker ARQ de scraping)
REDIS_URL=redis://localhost:6379
USE_ARQ_WORKER=true

# CORS (frontend Vite)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Rate limits scraping
WTTJ_CONCURRENCY=5
INDEED_CONCURRENCY=1
ATS_CONCURRENCY=10
INDEED_DELAY_SECONDS=3.0
